{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:contextport:schema:release-readiness:0.1",
  "title": "ContextPort release-readiness report 0.1",
  "type": "object",
  "required": ["readiness_version", "audited_revision", "versions", "session_fresh", "tests", "coverage", "schemas", "package", "demo", "authorship_pass", "context_port_only_scope", "private_export_artifacts_tracked", "production_dependencies", "private_runtime_dependency", "human_gates", "known_unsupported_capabilities", "automated_checks", "failed_automated_checks", "synthetic_mvp_status", "public_release_status", "release_blockers", "publication_performed", "readiness_report_sha256"],
  "properties": {
    "readiness_version": {"const": "0.1"},
    "audited_revision": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "versions": {"type": "object"},
    "session_fresh": {"const": true},
    "tests": {"type": "object"},
    "coverage": {"type": "object"},
    "schemas": {"type": "object"},
    "package": {"type": "object"},
    "demo": {"type": "object"},
    "authorship_pass": {"type": "boolean"},
    "context_port_only_scope": {"type": "boolean"},
    "private_export_artifacts_tracked": {"type": "boolean"},
    "production_dependencies": {"type": "array"},
    "private_runtime_dependency": {"type": "boolean"},
    "human_gates": {"type": "object"},
    "known_unsupported_capabilities": {"type": "array"},
    "automated_checks": {"type": "object"},
    "failed_automated_checks": {"type": "array"},
    "synthetic_mvp_status": {"enum": ["ready", "not_ready"]},
    "public_release_status": {"enum": ["ready", "not_ready", "blocked_human_decisions"]},
    "release_blockers": {"type": "array"},
    "publication_performed": {"const": false},
    "readiness_report_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  },
  "additionalProperties": true
}
